generator client {
  provider = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
}

model AcademicDate {
  id               Int      @id @default(autoincrement())
  key              String   @unique
  date             String
  targetRole       String
  notificationSent Boolean  @default(false)
  updatedAt        DateTime @updatedAt
}
